# Vite dev proxy target. Used only by vite.config.ts.
BACKEND_PROXY_TARGET=http://localhost:8080

# Local dev server. For mobile/ngrok demo, use:
# DEV_SERVER_HOST=0.0.0.0
# DEV_ALLOWED_HOSTS=your-ngrok-domain.ngrok-free.dev
DEV_SERVER_HOST=localhost
DEV_SERVER_PORT=5173
DEV_ALLOWED_HOSTS=

# Browser API base URL.
# Keep empty for local dev so requests go through Vite proxy.
# Set to https://api.your-domain.com when deploying frontend/backend separately.
VITE_API_BASE_URL=

# Google Identity Services client ID.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Must match backend BOOKING_SEAT_HOLD_MINUTES for consistent UI countdown.
VITE_BOOKING_SEAT_HOLD_MINUTES=2
